# Example environment variables for Stellar Voting App

# NEXT_PUBLIC_ variables are readable in the frontend.

# Base URL for the backend API (to be implemented in later steps)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Stellar Horizon endpoint (testnet)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Example secret for backend-only usage (do NOT commit real secrets)
BACKEND_STELLAR_SEED=TESTNET_PRIVATE_KEY_PLACEHOLDER

